# === GenLab-1C Web Platform ===
# Copy to .env and fill in values: cp .env.example .env

# ── Required ──

# JWT secret (generate: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=

# ── Optional (have sensible defaults) ──

# OpenRouter API (для генерации кода)
OPENROUTER_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://genlab:genlab@localhost:5432/genlab

# Начальный администратор (создаётся при первом запуске)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT token lifetime in hours
ACCESS_TOKEN_EXPIRE_HOURS=24
